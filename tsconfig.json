{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2017",
    "noImplicitAny": true,
    "strict": true,
    "alwaysStrict": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "experimentalDecorators": true,
    "skipLibCheck": true,
  },
  "include": [
    "src/**/*"
  ]
}
